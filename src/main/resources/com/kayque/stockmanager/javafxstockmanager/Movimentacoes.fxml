<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.kayque.stockmanager.javafxstockmanager.controller.MovimentacoesController">

    <Pane prefHeight="600.0" prefWidth="900.0"
          style="-fx-background-color: #f4f6f8;" />

    <HBox prefHeight="70.0" prefWidth="900.0"
          style="-fx-background-color: #1f2937; -fx-padding: 20;">
        <Label text="Movimentação de Estoque" style="-fx-text-fill: white;">
            <font>
                <Font size="24.0"/>
            </font>
        </Label>
    </HBox>

    <VBox layoutX="40.0" layoutY="95.0" prefWidth="820.0" spacing="12.0"
          style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 12;">

        <Label text="Registrar Entrada/Saída">
            <font>
                <Font size="22.0"/>
            </font>
        </Label>

        <HBox spacing="10.0">

            <TextField fx:id="campoProdutoId"
                       promptText="ID do produto"
                       prefWidth="180.0"
                       prefHeight="38.0"/>

            <ComboBox fx:id="comboTipo"
                      promptText="Tipo"
                      prefWidth="180.0"
                      prefHeight="38.0"/>

            <TextField fx:id="campoQuantidade"
                       promptText="Quantidade"
                       prefWidth="150.0"
                       prefHeight="38.0"/>

        </HBox>

        <HBox spacing="10.0">

            <Button text="Registrar"
                    onAction="#registrarMovimentacao"
                    prefHeight="38.0"
                    style="-fx-background-color: #1f2937; -fx-text-fill: white;" />

            <Button text="Atualizar Histórico"
                    onAction="#carregarHistorico"
                    prefHeight="38.0"
                    style="-fx-background-color: #374151; -fx-text-fill: white;" />

            <Button text="Voltar"
                    onAction="#voltar"
                    prefHeight="38.0"
                    style="-fx-background-color: #6b7280; -fx-text-fill: white;" />

        </HBox>

        <Label fx:id="labelMensagem" text="" />

        <TableView fx:id="tabelaMovimentacoes" prefHeight="300.0">
            <columns>
                <TableColumn fx:id="colunaId" text="ID" prefWidth="60.0" />
                <TableColumn fx:id="colunaProduto" text="Produto" prefWidth="220.0" />
                <TableColumn fx:id="colunaTipo" text="Tipo" prefWidth="120.0" />
                <TableColumn fx:id="colunaQuantidade" text="Quantidade" prefWidth="120.0" />
            </columns>
        </TableView>

    </VBox>

</AnchorPane>