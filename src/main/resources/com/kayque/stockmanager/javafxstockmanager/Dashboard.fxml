<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.kayque.stockmanager.javafxstockmanager.controller.DashboardController">

    <Pane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #f4f6f8;" />

    <HBox prefHeight="70.0" prefWidth="900.0"
          style="-fx-background-color: #1f2937; -fx-padding: 20;">
        <Label text="Stock Manager" style="-fx-text-fill: white;">
            <font>
                <Font size="24.0" />
            </font>
        </Label>
    </HBox>

    <VBox layoutX="40.0" layoutY="110.0" prefWidth="220.0" spacing="15.0"
          style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 12;">

        <Label text="Menu" style="-fx-text-fill: #111827;">
            <font>
                <Font size="22.0" />
            </font>
        </Label>

        <Button text="Produtos" maxWidth="Infinity" prefHeight="40.0"
                onAction="#abrirProdutos"
                style="-fx-background-color: #1f2937; -fx-text-fill: white; -fx-background-radius: 8;" />

        <Button text="Usuários" maxWidth="Infinity" prefHeight="40.0"
                onAction="#abrirUsuarios"
                style="-fx-background-color: #374151; -fx-text-fill: white; -fx-background-radius: 8;" />

        <Button text="Movimentações" maxWidth="Infinity" prefHeight="40.0"
                onAction="#abrirMovimentacoes"
                style="-fx-background-color: #374151; -fx-text-fill: white; -fx-background-radius: 8;" />

        <Button text="Sair" maxWidth="Infinity" prefHeight="40.0"
                onAction="#sair"
                style="-fx-background-color: #b91c1c; -fx-text-fill: white; -fx-background-radius: 8;" />

    </VBox>

    <VBox layoutX="300.0" layoutY="90.0" prefWidth="540.0" spacing="12.0"
          style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 12;">

        <Label text="Resumo do Estoque" style="-fx-text-fill: #111827;">
            <font>
                <Font size="24.0" />
            </font>
        </Label>

        <Label fx:id="labelTotalProdutos" text="Produtos cadastrados: 0"/>
        <Label fx:id="labelEstoqueBaixo" text="Produtos com estoque baixo: 0"/>
        <Label fx:id="labelSemEstoque" text="Produtos sem estoque: 0"/>
        <Label fx:id="labelValorTotal" text="Valor total em estoque: R$ 0,00"/>

        <HBox spacing="10.0">

            <PieChart fx:id="graficoStatus"
                      prefWidth="250.0"
                      prefHeight="260.0"
                      title="Status do Estoque"/>

            <BarChart fx:id="graficoCategorias"
                      prefWidth="260.0"
                      prefHeight="260.0"
                      title="Produtos por Categoria">
                <xAxis>
                    <CategoryAxis label="Categoria"/>
                </xAxis>
                <yAxis>
                    <NumberAxis label="Total"/>
                </yAxis>
            </BarChart>

        </HBox>

    </VBox>

</AnchorPane>