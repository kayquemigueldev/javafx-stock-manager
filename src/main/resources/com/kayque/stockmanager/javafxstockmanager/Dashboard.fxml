<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.kayque.stockmanager.javafxstockmanager.controller.DashboardController">

    <Pane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #f4f6f8;" />

    <HBox prefHeight="70.0" prefWidth="900.0"
          style="-fx-background-color: #111827; -fx-padding: 20;">
        <Label text="Stock Manager"
               style="-fx-text-fill: white;">
            <font>
                <Font size="24.0" />
            </font>
        </Label>
    </HBox>

    <VBox layoutX="35.0" layoutY="100.0" prefWidth="210.0" spacing="14.0"
          style="-fx-background-color: white; -fx-padding: 22; -fx-background-radius: 14;">

        <Label text="Menu" style="-fx-text-fill: #111827;">
            <font>
                <Font size="22.0" />
            </font>
        </Label>

        <Button text="Produtos" maxWidth="Infinity" prefHeight="40.0"
                onAction="#abrirProdutos"
                style="-fx-background-color: #111827; -fx-text-fill: white; -fx-background-radius: 8;" />

        <Button text="Usuários" maxWidth="Infinity" prefHeight="40.0"
                onAction="#abrirUsuarios"
                style="-fx-background-color: #374151; -fx-text-fill: white; -fx-background-radius: 8;" />

        <Button text="Movimentações" maxWidth="Infinity" prefHeight="40.0"
                onAction="#abrirMovimentacoes"
                style="-fx-background-color: #374151; -fx-text-fill: white; -fx-background-radius: 8;" />

        <Button text="Sair" maxWidth="Infinity" prefHeight="40.0"
                onAction="#sair"
                style="-fx-background-color: #b91c1c; -fx-text-fill: white; -fx-background-radius: 8;" />

    </VBox>

    <VBox layoutX="270.0" layoutY="95.0" prefWidth="595.0" spacing="18.0">

        <Label text="Dashboard" style="-fx-text-fill: #111827;">
            <font>
                <Font size="30.0" />
            </font>
        </Label>

        <HBox spacing="15.0">

            <VBox prefWidth="135.0" prefHeight="95.0" spacing="8.0"
                  style="-fx-background-color: white; -fx-padding: 16; -fx-background-radius: 14;">
                <Label text="Produtos" style="-fx-text-fill: #6b7280;" />
                <Label fx:id="labelTotalProdutos" text="0" style="-fx-text-fill: #111827;">
                    <font>
                        <Font size="24.0" />
                    </font>
                </Label>
            </VBox>

            <VBox prefWidth="135.0" prefHeight="95.0" spacing="8.0"
                  style="-fx-background-color: white; -fx-padding: 16; -fx-background-radius: 14;">
                <Label text="Baixo estoque" style="-fx-text-fill: #6b7280;" />
                <Label fx:id="labelEstoqueBaixo" text="0" style="-fx-text-fill: #ca8a04;">
                    <font>
                        <Font size="24.0" />
                    </font>
                </Label>
            </VBox>

            <VBox prefWidth="135.0" prefHeight="95.0" spacing="8.0"
                  style="-fx-background-color: white; -fx-padding: 16; -fx-background-radius: 14;">
                <Label text="Sem estoque" style="-fx-text-fill: #6b7280;" />
                <Label fx:id="labelSemEstoque" text="0" style="-fx-text-fill: #dc2626;">
                    <font>
                        <Font size="24.0" />
                    </font>
                </Label>
            </VBox>

            <VBox prefWidth="145.0" prefHeight="95.0" spacing="8.0"
                  style="-fx-background-color: white; -fx-padding: 16; -fx-background-radius: 14;">
                <Label text="Valor estoque" style="-fx-text-fill: #6b7280;" />
                <Label fx:id="labelValorTotal" text="R$ 0,00" style="-fx-text-fill: #15803d;">
                    <font>
                        <Font size="18.0" />
                    </font>
                </Label>
            </VBox>

        </HBox>

        <HBox spacing="15.0">

            <VBox prefWidth="285.0" prefHeight="310.0"
                  style="-fx-background-color: white; -fx-padding: 12; -fx-background-radius: 14;">
                <PieChart fx:id="graficoStatus"
                          prefWidth="260.0"
                          prefHeight="280.0"
                          title="Status do Estoque"/>
            </VBox>

            <VBox prefWidth="295.0" prefHeight="310.0"
                  style="-fx-background-color: white; -fx-padding: 12; -fx-background-radius: 14;">
                <BarChart fx:id="graficoCategorias"
                          prefWidth="270.0"
                          prefHeight="280.0"
                          title="Produtos por Categoria">
                    <xAxis>
                        <CategoryAxis label="Categoria"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Total"/>
                    </yAxis>
                </BarChart>
            </VBox>

        </HBox>

    </VBox>

</AnchorPane>