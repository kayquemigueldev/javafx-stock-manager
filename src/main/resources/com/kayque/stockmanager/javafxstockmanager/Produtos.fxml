<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.kayque.stockmanager.javafxstockmanager.controller.ProdutosController">

    <Pane prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #f4f6f8;" />

    <HBox prefHeight="70.0" prefWidth="900.0"
          style="-fx-background-color: #1f2937; -fx-padding: 20;">
        <Label text="Produtos" style="-fx-text-fill: white;">
            <font>
                <Font size="24.0" />
            </font>
        </Label>
    </HBox>

    <VBox layoutX="40.0" layoutY="95.0" prefWidth="820.0" spacing="12.0"
          style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 12;">

        <HBox spacing="10.0">
            <TextField fx:id="campoNome" promptText="Nome" prefWidth="150.0" />
            <TextField fx:id="campoDescricao" promptText="Descrição" prefWidth="180.0" />
            <TextField fx:id="campoCategoria" promptText="Categoria" prefWidth="130.0" />
            <TextField fx:id="campoPreco" promptText="Preço" prefWidth="100.0" />
            <TextField fx:id="campoQuantidade" promptText="Qtd" prefWidth="80.0" />
        </HBox>

        <Button text="Salvar Produto"
                onAction="#salvarProduto"
                prefHeight="38.0"
                style="-fx-background-color: #1f2937; -fx-text-fill: white;" />

        <Button text="Atualizar Produto"
                onAction="#atualizarProduto"
                prefHeight="38.0"
                style="-fx-background-color: #2563eb; -fx-text-fill: white;" />

        <Button text="Excluir Produto"
                onAction="#excluirProduto"
                prefHeight="38.0"
                style="-fx-background-color: #dc2626; -fx-text-fill: white;" />

        <Button text="Atualizar Lista"
                onAction="#carregarProdutos"
                prefHeight="38.0"
                style="-fx-background-color: #374151; -fx-text-fill: white;" />

        <Button text="Voltar"
                onAction="#voltar"
                prefHeight="38.0"
                style="-fx-background-color: #6b7280; -fx-text-fill: white;" />

        <Label fx:id="labelMensagem" text="" />

        <TableView fx:id="tabelaProdutos" prefHeight="330.0">
            <columns>
                <TableColumn fx:id="colunaId" text="ID" prefWidth="60.0" />
                <TableColumn fx:id="colunaNome" text="Nome" prefWidth="160.0" />
                <TableColumn fx:id="colunaCategoria" text="Categoria" prefWidth="140.0" />
                <TableColumn fx:id="colunaPreco" text="Preço" prefWidth="120.0" />
                <TableColumn fx:id="colunaQuantidade" text="Qtd" prefWidth="90.0" />
                <TableColumn fx:id="colunaDescricao" text="Descrição" prefWidth="220.0" />
                <TableColumn fx:id="colunaStatus" text="Status" prefWidth="130.0" />
            </columns>
        </TableView>

    </VBox>

</AnchorPane>