<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.kayque.stockmanager.javafxstockmanager.controller.LogsController">

    <Pane prefHeight="600.0" prefWidth="900.0"
          style="-fx-background-color: #f4f6f8;" />

    <HBox prefHeight="70.0" prefWidth="900.0"
          style="-fx-background-color: #111827; -fx-padding: 20;">
        <Label text="Logs do Sistema" style="-fx-text-fill: white;">
            <font>
                <Font size="24.0" />
            </font>
        </Label>
    </HBox>

    <VBox layoutX="40.0" layoutY="100.0" prefWidth="820.0" spacing="15.0"
          style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 12;">

        <Label text="Auditoria de Ações" style="-fx-text-fill: #111827;">
            <font>
                <Font size="24.0" />
            </font>
        </Label>

        <TableView fx:id="tabelaLogs" prefHeight="360.0">
            <columns>
                <TableColumn fx:id="colunaId" text="ID" prefWidth="60.0" />
                <TableColumn fx:id="colunaUsuario" text="Usuário" prefWidth="150.0" />
                <TableColumn fx:id="colunaAcao" text="Ação" prefWidth="420.0" />
                <TableColumn fx:id="colunaDataHora" text="Data/Hora" prefWidth="180.0" />
            </columns>
        </TableView>

        <HBox spacing="10.0">
            <Button text="Atualizar"
                    onAction="#carregarLogs"
                    prefHeight="38.0"
                    style="-fx-background-color: #374151; -fx-text-fill: white;" />

            <Button text="Voltar"
                    onAction="#voltar"
                    prefHeight="38.0"
                    style="-fx-background-color: #6b7280; -fx-text-fill: white;" />
        </HBox>

    </VBox>

</AnchorPane>