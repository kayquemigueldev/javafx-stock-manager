<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="600.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1">

    <Pane prefHeight="600.0" prefWidth="900.0"
          style="-fx-background-color: #f4f6f8;" />

    <VBox layoutX="300.0" layoutY="130.0" prefWidth="300.0" spacing="18.0"
          style="-fx-background-color: white; -fx-padding: 35; -fx-background-radius: 12;">

        <Label text="Stock Manager">
            <font>
                <Font size="26.0" />
            </font>
        </Label>

        <Label text="Acesse sua conta" style="-fx-text-fill: #666;" />

        <TextField promptText="Usuário" prefHeight="38.0" />

        <PasswordField promptText="Senha" prefHeight="38.0" />

        <Button text="Entrar" prefHeight="40.0" maxWidth="Infinity"
                style="-fx-background-color: #1f2937; -fx-text-fill: white; -fx-background-radius: 8;" />

    </VBox>

</AnchorPane>